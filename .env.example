# Copy to `.env` and adjust. Most app vars use the LEGAL_ prefix (see src/config.py).
# `HF_TOKEN` is an exception (no prefix); it is loaded by python-dotenv from this file.

# --- LLM (Ollama) ---
# Use http://127.0.0.1:11434 for local `uvicorn`. For `docker compose`, use
# http://host.docker.internal:11434 (or omit this line so compose.yml's default applies).
LEGAL_OLLAMA_BASE_URL=http://127.0.0.1:11434
LEGAL_OLLAMA_MODEL=llama3.2

# --- Embeddings (sentence-transformers; first run may download weights) ---
LEGAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Data paths (relative to process working directory) ---
LEGAL_DATA_DIR=data
LEGAL_CHROMA_PATH=data/chroma
LEGAL_FEEDBACK_DB_PATH=data/feedback.db
LEGAL_UPLOADS_DIR=data/uploads

# --- Retrieval / chunking ---
LEGAL_CHUNK_SIZE=900
LEGAL_CHUNK_OVERLAP=120
LEGAL_RETRIEVE_TOP_K=8
# Fetch top_k * multiplier candidates, then drop duplicate chunk text (re-ingested PDFs).
LEGAL_RETRIEVE_DEDUP_MULTIPLIER=2
LEGAL_OCR_MIN_CHARS_PER_PAGE=50
# Cap frames/pages OCR'd per image upload (multi-page TIFF).
LEGAL_INGEST_MAX_IMAGE_FRAMES=48
# If true, POST /draft returns 422 when the model cites [n] outside retrieved evidence (draft not saved).
LEGAL_STRICT_CITATIONS=false
LEGAL_FEEDBACK_FEW_SHOT_LIMIT=5

# Optional: Hugging Face cache (embeddings model)
# HF_HOME=/path/to/hf_cache

# Hugging Face Hub (not a LEGAL_ var — loaded via python-dotenv for local runs; for `docker compose`,
# the same line is read from this file on the host and passed into the container — see docker-compose.yml)
# Create a token: https://huggingface.co/settings/tokens
# HF_TOKEN=hf_your_token_here
# Or store credentials via CLI: hf auth login   (use `hf`, not deprecated huggingface-cli)

# Application log file (append mode)
LEGAL_LOG_FILE=logs/log.log
